{
  "name": "ai-db-client",
  "version": "0.1.2",
  "description": "Local-first database client MCP server for AI agents.",
  "type": "module",
  "bin": {
    "ai-db-client-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "npm run check && rm -rf dist && ncc build src/index.ts -o dist --no-cache",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "mysql2": "^3.15.3",
    "pg": "^8.16.3",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
